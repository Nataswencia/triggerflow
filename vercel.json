{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/lead-hunter", "destination": "/ai/lead-hunter", "permanent": true },
    { "source": "/lead-hunter.html", "destination": "/ai/lead-hunter", "permanent": true },
    { "source": "/inbox-zero", "destination": "/ai/inbox-zero", "permanent": true },
    { "source": "/inbox-zero.html", "destination": "/ai/inbox-zero", "permanent": true },
    { "source": "/job-hunter", "destination": "/ai/job-hunter", "permanent": true },
    { "source": "/job-hunter.html", "destination": "/ai/job-hunter", "permanent": true },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/sitemoney-scan",
      "destination": "https://triggerflow.pro/sitemoney-scan",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/services",
      "destination": "https://triggerflow.pro/services",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/money-leak-audit",
      "destination": "https://triggerflow.pro/money-leak-audit",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/subscription",
      "destination": "https://triggerflow.pro/subscription",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/pricing",
      "destination": "https://triggerflow.pro/pricing",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/about",
      "destination": "https://triggerflow.pro/about",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/blog",
      "destination": "https://triggerflow.pro/blog",
      "permanent": false
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/google-ads-scan",
      "destination": "https://triggerflow.pro/google-ads-scan",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/lead-hunter",
      "destination": "/ai/lead-hunter.html"
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/inbox-zero",
      "destination": "/ai/inbox-zero.html"
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/job-hunter",
      "destination": "/ai/job-hunter.html"
    },
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/",
      "destination": "/ai/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
