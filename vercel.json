{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "has": [{ "type": "host", "value": "ai.triggerflow.pro" }],
      "source": "/(.*)",
      "destination": "/ai/$1"
    }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/lead-hunter", "destination": "https://ai.triggerflow.pro/lead-hunter", "permanent": true },
    { "source": "/lead-hunter.html", "destination": "https://ai.triggerflow.pro/lead-hunter", "permanent": true },
    { "source": "/inbox-zero", "destination": "https://ai.triggerflow.pro/inbox-zero", "permanent": true },
    { "source": "/inbox-zero.html", "destination": "https://ai.triggerflow.pro/inbox-zero", "permanent": true },
    { "source": "/job-hunter", "destination": "https://ai.triggerflow.pro/job-hunter", "permanent": true },
    { "source": "/job-hunter.html", "destination": "https://ai.triggerflow.pro/job-hunter", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
